{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-user-personas.local/schemas/persona.schema.json",
  "title": "AI User Persona",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "status",
    "name",
    "archetype",
    "role",
    "summary",
    "primary_goal",
    "goals",
    "frustrations",
    "motivations",
    "behaviors",
    "needs",
    "scenarios",
    "evidence",
    "confidence",
    "tags",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^persona_[a-z0-9][a-z0-9-]*_[a-f0-9]{8}$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived"]
    },
    "name": {
      "$ref": "#/$defs/non_empty_string"
    },
    "archetype": {
      "$ref": "#/$defs/non_empty_string"
    },
    "role": {
      "$ref": "#/$defs/non_empty_string"
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600
    },
    "primary_goal": {
      "$ref": "#/$defs/non_empty_string"
    },
    "goals": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "frustrations": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "motivations": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "behaviors": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "needs": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      },
      "uniqueItems": true,
      "default": []
    },
    "quote": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "channels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true,
      "default": []
    },
    "tech_comfort": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "decision_style": {
      "type": "string",
      "enum": ["fast", "deliberate", "consensus", "authority-led"]
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "created_at": {
      "$ref": "#/$defs/iso_datetime"
    },
    "updated_at": {
      "$ref": "#/$defs/iso_datetime"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "iso_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 600
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source_type", "summary", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^evidence_[a-z0-9][a-z0-9-]*_[a-f0-9]{8}$"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "interview",
            "survey",
            "analytics",
            "support",
            "sales",
            "desk_research",
            "synthetic"
          ]
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_uri": {
          "type": "string",
          "minLength": 1
        },
        "quote": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 800
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "observed_at": {
          "$ref": "#/$defs/iso_datetime"
        }
      }
    }
  }
}
